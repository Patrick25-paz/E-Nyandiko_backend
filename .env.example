# Seed (local/dev)
# npm run seed
# By default it seeds:
# - admin@enyandiko.com (ADMIN)
# - seller@enyandiko.com (SELLER)
# - buyer@enyandiko.com (BUYER)
# Use SEED_UPDATE_PASSWORDS=true to overwrite existing passwords.
